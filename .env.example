# ── Server ─────────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── Database ───────────────────────────────────────────────────────────────────
# Local:  mongodb://localhost:27017/home-services
# Atlas:  mongodb+srv://<user>:<password>@cluster.mongodb.net/home-services
MONGO_URI=mongodb://localhost:27017/home-services

# ── JWT ────────────────────────────────────────────────────────────────────────
# Generate strong secrets: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=your_access_token_secret_here
JWT_REFRESH_SECRET=your_refresh_token_secret_here
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── File Uploads ───────────────────────────────────────────────────────────────
MAX_FILE_SIZE_MB=5
UPLOAD_DIR=uploads/evidence

# ── Rate Limiting ──────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# ── CORS ───────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173